# Copy this to .env and fill in your key for local testing
# DO NOT commit .env to git
GEMINI_API_KEY=your-gemini-api-key-here
USER_PROMPT=a counter app with a +1 button and a reset button
# v2 default: gemini-3.5-flash. Override with -lite for speed or -pro for quality.
GEMINI_MODEL=gemini-3.5-flash
# Optional: use a different (usually smarter) model for the review pass.
# Defaults to the same as GEMINI_MODEL.
# GEMINI_REVIEW_MODEL=gemini-3.1-pro-preview
